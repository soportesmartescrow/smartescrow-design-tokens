{
  "name": "@smartescrow/design-system",
  "version": "1.3.1",
  "description": "Design system SmartEscrow (--se-*): tokens (paleta slate+verde, tipografía Poppins, radios, sombras, espaciado, z-index, modo oscuro), tema Vuetify, componentes reutilizables, navbar (patrón sidebar→header) y adaptador EasyAdmin. Portable a cualquier plataforma.",
  "type": "module",
  "license": "UNLICENSED",
  "author": "SmartEscrow Team",
  "keywords": ["design-tokens", "design-system", "css-variables", "components", "navbar", "easyadmin", "vuetify", "prontopago", "smartescrow"],
  "main": "./tokens.mjs",
  "module": "./tokens.mjs",
  "exports": {
    ".": "./tokens.mjs",
    "./css": "./tokens.css",
    "./tokens.css": "./tokens.css",
    "./fonts": "./fonts.css",
    "./fonts.css": "./fonts.css",
    "./components": "./components.css",
    "./components.css": "./components.css",
    "./navbar.css": "./navbar.css",
    "./navbar.js": "./navbar.js",
    "./navbar.global.js": "./navbar.global.js",
    "./navbar.html": "./navbar.html",
    "./easyadmin": "./adapters/easyadmin.css",
    "./vuetify": "./vuetify-theme.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "tokens.mjs",
    "tokens.css",
    "fonts.css",
    "components.css",
    "navbar.css",
    "navbar.js",
    "navbar.global.js",
    "navbar.html",
    "adapters/easyadmin.css",
    "vuetify-theme.mjs",
    "build-tokens.mjs",
    "README.md",
    "CLAUDE.md"
  ],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "node build-tokens.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soportesmartescrow/smartescrow-design-tokens.git"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
