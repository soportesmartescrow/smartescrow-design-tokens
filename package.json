  "exports": {
    ".": "./tokens.mjs",
    "./css": "./tokens.css",
    "./tokens.css": "./tokens.css",
    "./vuetify": "./vuetify-theme.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "tokens.mjs",
    "tokens.css",
    "vuetify-theme.mjs",
